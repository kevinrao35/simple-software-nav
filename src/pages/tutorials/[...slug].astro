---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials');
  return tutorials.map(t => ({
    params: { slug: t.id },
    props: { entry: t },
  }));
}

const { entry } = Astro.props;
const { data } = entry;

const body = entry.body || '';
const lines = body.split('\n');

// Parse sections from markdown
interface Section {
  title: string;
  content: string[];
}

const sections: Section[] = [];
let currentTitle = '';
let currentContent: string[] = [];

for (const line of lines) {
  if (line.startsWith('## ')) {
    if (currentTitle) {
      sections.push({ title: currentTitle, content: currentContent });
    }
    currentTitle = line.replace('## ', '').trim();
    currentContent = [];
  } else if (line.startsWith('# ') || line.startsWith('---')) {
    continue;
  } else {
    currentContent.push(line);
  }
}
if (currentTitle) {
  sections.push({ title: currentTitle, content: currentContent });
}
---

<Layout
  title={`${data.title} - 教程`}
  description={data.description}
  type="article"
  jsonLd={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "首页", "item": "https://soft.chanxi.vip/" },
        { "@type": "ListItem", "position": 2, "name": "教程", "item": "https://soft.chanxi.vip/tutorials/" },
        { "@type": "ListItem", "position": 3, "name": data.title }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": data.title,
      "description": data.description,
      "about": { "@type": "SoftwareApplication", "name": data.software },
      "proficiencyLevel": data.difficulty === 'beginner' ? 'Beginner' : data.difficulty === 'intermediate' ? 'Intermediate' : 'Advanced',
      "inLanguage": "zh-CN"
    }
  ])}
>
  <div class="tutorial-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/tutorials">&larr; 返回教程列表</a>
        <span class="sep">/</span>
        <span>{data.software}</span>
      </div>
      <h1>{data.title}</h1>
      <div class="meta">
        <span class="difficulty" data-level={data.difficulty}>
          {data.difficulty === 'beginner' ? '入门' : data.difficulty === 'intermediate' ? '进阶' : '高级'}
        </span>
        <span class="software">软件：{data.software}</span>
      </div>
      <p class="desc">{data.description}</p>
    </div>
  </div>

  <div class="tutorial-body">
    <div class="container">
      <div class="toc">
        <h3>目录</h3>
        <ul>
          {sections.filter(s => s.title).map(s => (
            <li><a href={`#section-${sections.indexOf(s)}`}>{s.title}</a></li>
          ))}
        </ul>
      </div>

      <div class="content">
        {sections.filter(s => s.title).map((section, idx) => (
          <div class="section" id={`section-${idx}`}>
            <h2>{section.title}</h2>
            <div class="section-body">
              {section.content.filter(l => l.trim()).map(line => {
                if (line.startsWith('- ')) {
                  const text = line.replace(/^- /, '');
                  return <p class="list-item" set:html={text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')} />;
                }
                if (line.startsWith('1. ') || line.startsWith('2. ') || line.startsWith('3. ') || line.startsWith('4. ') || line.startsWith('5. ') || line.startsWith('6. ') || line.startsWith('7. ') || line.startsWith('8. ') || line.startsWith('9. ')) {
                  const text = line.replace(/^\d+\.\s+/, '');
                  return <p class="step-item" set:html={`<span class="step-num">${line.match(/^\d+/)[0]}</span> ${text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')}`} />;
                }
                if (line.startsWith('```')) return null;
                return <p set:html={line.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/`(.+?)`/g, '<code>$1</code>')} />;
              })}
            </div>
          </div>
        ))}
      </div>

      <div class="related-software">
        <a href={`/software/${data.softwareSlug}`} class="back-to-software">
          &larr; 查看 {data.software} 软件详情
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .tutorial-hero {
    background: var(--card-bg);
    border-bottom: 1px solid var(--border);
    padding: 32px 0;
  }

  .container { max-width: 860px; margin: 0 auto; padding: 0 24px; }

  .breadcrumb {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 16px;
  }

  .breadcrumb a { color: var(--accent); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .sep { margin: 0 8px; }

  .tutorial-hero h1 {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 12px;
  }

  .meta {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 12px;
  }

  .difficulty {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 3px 12px;
    border-radius: 20px;
  }

  .difficulty[data-level="beginner"] { background: #ecfdf5; color: #059669; }
  .difficulty[data-level="intermediate"] { background: #fef3c7; color: #d97706; }
  .difficulty[data-level="advanced"] { background: #fee2e2; color: #dc2626; }

  .software {
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 500;
  }

  .desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .tutorial-body {
    padding: 32px 0;
  }

  .toc {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 24px;
    margin-bottom: 32px;
  }

  .toc h3 {
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--text);
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc li {
    margin-bottom: 6px;
  }

  .toc li a {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .toc li a:hover {
    text-decoration: underline;
  }

  .section {
    margin-bottom: 36px;
    scroll-margin-top: 80px;
  }

  .section h2 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--accent);
  }

  .section-body p {
    margin-bottom: 10px;
    line-height: 1.8;
    color: var(--text);
    font-size: 0.95rem;
  }

  .section-body code {
    background: #f3f4f6;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.85em;
    color: #e11d48;
  }

  .list-item {
    padding-left: 16px;
    position: relative;
  }

  .list-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .step-item {
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }

  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--accent);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .related-software {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .back-to-software {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }

  .back-to-software:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .tutorial-hero h1 { font-size: 1.4rem; }
  }
</style>
