---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'software'>;
}

const { entry } = Astro.props;
const { data } = entry;

function stars(rating: number) {
  const full = Math.floor(rating);
  const half = rating % 1 >= 0.5 ? 1 : 0;
  return '★'.repeat(full) + (half ? '☆' : '') + '☆'.repeat(5 - full - half);
}

const platformIcons: Record<string, string> = {
  Windows: '🪟',
  macOS: '🍎',
  Linux: '🐧',
  iOS: '📱',
  Android: '🤖',
  网页: '🌐',
};
---

<a href={`/software/${entry.id}`} class="card">
  <div class="card-header">
    <span class="card-category">{data.类别}</span>
    <span class="card-rating" title={`${data.评分} 分`}>{stars(data.评分)}</span>
  </div>
  <h3 class="card-title">{data.软件名称}</h3>
  <p class="card-desc">{entry.body?.trim().split('\n')[0]?.replace(/^#\s+/, '') || data.英文名称}</p>
  <div class="card-meta">
    <div class="card-platforms">
      {data.平台.map(p => (
        <span class="platform-tag" title={p}>{platformIcons[p] || p}</span>
      ))}
    </div>
    {data.平替 && data.平替 !== '' && (
      <span class="card-alt">平替 {typeof data.平替 === 'string' ? data.平替 : data.平替.join('/')}</span>
    )}
  </div>
  <div class="card-tags">
    {data.标签.filter(t => !['免费软件', '开源'].includes(t)).slice(0, 3).map(t => (
      <span class="tag">{t}</span>
    ))}
  </div>
</a>

<style>
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: all 0.2s ease;
    box-shadow: var(--shadow);
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
    border-color: var(--accent-light);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-category {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--tag-text);
    background: var(--tag-bg);
    padding: 2px 10px;
    border-radius: 20px;
  }

  .card-rating {
    color: var(--rating-color);
    font-size: 0.85rem;
    letter-spacing: 1px;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }

  .card-platforms {
    display: flex;
    gap: 4px;
  }

  .platform-tag {
    font-size: 1rem;
    line-height: 1;
  }

  .card-alt {
    font-size: 0.75rem;
    color: var(--accent);
    background: var(--tag-bg);
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 500;
  }

  .card-tags {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.7rem;
    color: var(--text-secondary);
    background: var(--bg);
    padding: 2px 8px;
    border-radius: 4px;
  }
</style>
